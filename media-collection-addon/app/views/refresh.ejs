<%
  /*
   * views/refresh.ejs
   * Zeigt MusicBrainz-Vorschläge für einen Eintrag.
   * Der Nutzer wählt einen Treffer aus – erst dann werden Daten übernommen.
   */
%>
<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= __('refresh_page_title') %> – VinylVault</title>
  <link rel="stylesheet" href="<%= base %>/public/style.css?v=<%= assetVersion %>" />
  <link rel="stylesheet" href="<%= base %>/public/themes.css?v=<%= assetVersion %>" />
  <%- include('partials/head-i18n') %>
</head>
<body>
  <header class="site-header">
    <a class="logo" href="<%= base %>/">
      <span class="logo-icon">🎵</span>
      <span class="logo-text">VinylVault</span>
    </a>
    <div class="nav-wrap">
      <nav class="nav-primary">
        <a class="btn btn-ghost nav-link-collection" href="<%= base %>/"><span class="btn-icon"><svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="2" /><circle cx="12" cy="12" r="2" fill="currentColor" /></svg></span><span class="btn-label"><%= __('nav_collection') %></span></a>
        <a href="<%= base %>/items/wishlist-add" class="btn btn-secondary"><span class="btn-icon">♥</span><span class="btn-label"><%= __('nav_wishlist') %></span></a>
        <a href="<%= base %>/items/add" class="btn btn-primary"><span class="btn-icon">+</span><span class="btn-label"><%= __('nav_add') %></span></a>
        <details class="nav-more nav-main">
          <summary class="nav-more-btn" aria-label="Menue">Menu</summary>
          <div class="nav-more-panel">
            <details class="nav-more-sub">
              <summary class="nav-more-sub-btn">CSV</summary>
              <div class="nav-more-sub-panel">
                <a href="<%= base %>/csv"><%= __('nav_csv_import') %></a>
                <a href="<%= base %>/csv/export"><%= __('nav_csv_export') %></a>
              </div>
            </details>
            <a href="<%= base %>/items/bulk-refresh"><%= __('nav_bulk_analysis') %></a>
            <details class="nav-more-sub">
              <summary class="nav-more-sub-btn">Theme</summary>
              <div class="nav-more-sub-panel nav-theme-panel">
                <a href="javascript:void(0)" class="theme-option" data-theme="amber">Amber</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="dark">Dark</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="forest">Forest</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="gold">Gold</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="jazz">Jazz</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="matrix">Matrix</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="midnight">Midnight</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="ocean">Ocean</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="punk">Punk</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="retro">Retro</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="ruby">Ruby</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="slate">Slate</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="sunset">Sunset</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="synthwave">Synthwave</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="vinyl">Vinyl</a>
              </div>
            </details>
            <div class="nav-lang-group">
              <a href="javascript:void(0)" onclick="setLang('de')" class="lang-option<%= lang === 'de' ? ' active' : '' %>">DE</a>
              <a href="javascript:void(0)" onclick="setLang('en')" class="lang-option<%= lang === 'en' ? ' active' : '' %>">EN</a>
            </div>
          </div>
        </details>
      </nav>
    </div>
  </header>

  <main class="container">
    <a href="<%= base %>/items/<%= item.id %>" class="back-link">&larr; <%= __('back_to_entry').replace('{title}', item.title) %></a>
    <h1 class="page-title"><%= __('refresh_page_title') %></h1>

    <!-- ── Aktueller Stand ──────────────────────────────────────────────── -->
    <div class="refresh-current">
      <h2 class="refresh-section-title"><%= __('current_entry') %></h2>
      <div class="refresh-current-card">
        <div class="result-cover">
          <% if (item.cover_url) { %>
            <img src="<%= item.cover_url %>" alt="<%= item.title %>" loading="lazy" />
          <% } else { %>
            <div class="cover-placeholder"><span>🎵</span></div>
          <% } %>
        </div>
        <div class="result-info">
          <p class="result-title"><%= item.title %></p>
          <p class="result-artist"><%= item.artist || '–' %></p>
          <p class="result-year"><%= item.year || '–' %></p>
          <% if (item.mbid) { %>
            <p class="refresh-mbid-note"><%= __('mbid_present') %></p>
          <% } else { %>
            <p class="refresh-mbid-note refresh-mbid-missing"><%= __('mbid_missing') %></p>
          <% } %>
        </div>
      </div>
    </div>

    <!-- ── Fehler ────────────────────────────────────────────────────────── -->
    <% if (searchError) { %>
      <div class="alert alert-error"><%= searchError %></div>
    <% } %>

    <!-- ── Vorschläge ────────────────────────────────────── -->
    <% if (!searchError) { %>
      <h2 class="refresh-section-title">
        <%= __('mb_suggestions') %>
        <span class="refresh-hint"><%= __('click_to_apply') %></span>
      </h2>

      <% if (!suggestions || suggestions.length === 0) { %>
        <div class="empty-state">
          <p><%= __('no_results_for') %> „<strong><%= item.title %></strong>“
            <% if (item.artist) { %> <%= __('by_artist') %> <strong><%= item.artist %></strong><% } %>.</p>
          <p><%= __('tip_adjust') %></p>
        </div>
      <% } else { %>
        <div class="refresh-results">
          <% for (const s of suggestions) { %>
            <form
              class="refresh-card"
              method="post"
              action="<%= base %>/items/<%= item.id %>/refresh/apply"
            >
              <input type="hidden" name="title"     value="<%= s.title     || '' %>" />
              <input type="hidden" name="artist"    value="<%= s.artist    || '' %>" />
              <input type="hidden" name="year"      value="<%= s.year      || '' %>" />
              <input type="hidden" name="cover_url" value="<%= s.cover_url || '' %>" />
              <input type="hidden" name="mbid"      value="<%= s.mbid      || '' %>" />
              <input type="hidden" name="genre"     value="<%= s.genre     || '' %>" />
              <button type="submit" class="refresh-card-btn">
                <div class="result-cover">
                  <% if (s.cover_url) { %>
                    <img
                      src="<%= s.cover_url %>"
                      alt="<%= s.title %>"
                      loading="lazy"
                      onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
                    />
                    <div class="cover-placeholder" style="display:none"><span>?</span></div>
                  <% } else { %>
                    <div class="cover-placeholder"><span>?</span></div>
                  <% } %>
                </div>
              <div class="result-info">
                  <p class="result-title"><%= s.title %></p>
                  <p class="result-artist"><%= s.artist || '–' %></p>
                  <p class="result-year">
                    <%= s.year || '–' %>
                    <% if (s.type) { %><span class="result-type"> · <%= s.type %></span><% } %>
                    <% if (s.score != null) { %>
                      <span class="refresh-score refresh-score--<%= s.score >= 90 ? 'high' : s.score >= 60 ? 'mid' : 'low' %>">
                        <%= s.score %>%
                      </span>
                    <% } %>
                  </p>
                  <% if (s.genre) { %>
                    <p class="result-genre"><%= s.genre %></p>
                  <% } %>
                </div>
                <span class="result-add-icon">✔</span>
              </button>
            </form>
          <% } %>
        </div>
      <% } %>
    <% } %>

    <!-- ── Abbrechen ────────────────────────────────────────────────────── -->
    <div class="form-actions" style="margin-top: 2rem">
      <a href="<%= base %>/items/<%= item.id %>" class="btn btn-ghost"><%= __('cancel_no_apply') %></a>
    </div>
  </main>

  <footer class="site-footer">
    <small><%= __('footer') %></small>
  </footer>
  <script src="<%= base %>/public/theme-selector.js?v=<%= assetVersion %>"></script>
</body>
</html>
