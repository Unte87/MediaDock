<%
  /*
   * views/detail.ejs
   * Detail view for a single media item.
   * Allows editing notes, toggling owned/wishlist and deleting the entry.
   */
%>
<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= item.title %> – VinylVault</title>
  <link rel="stylesheet" href="<%= base %>/public/style.css?v=<%= assetVersion %>" />
  <link rel="stylesheet" href="<%= base %>/public/themes.css?v=<%= assetVersion %>" />
  <%- include('partials/head-i18n') %>
</head>
<body>
  <header class="site-header">
    <a class="logo" href="<%= base %>/">
      <span class="logo-icon">🎵</span>
      <span class="logo-text">VinylVault</span>
    </a>
    <div class="nav-wrap">
      <nav class="nav-primary">
        <a class="btn btn-ghost nav-link-collection" href="<%= base %>/"><span class="btn-icon"><svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="2" /><circle cx="12" cy="12" r="2" fill="currentColor" /></svg></span><span class="btn-label"><%= __('nav_collection') %></span></a>
        <a href="<%= base %>/items/wishlist-add" class="btn btn-secondary"><span class="btn-icon">♥</span><span class="btn-label"><%= __('nav_wishlist') %></span></a>
        <a href="<%= base %>/items/add" class="btn btn-primary"><span class="btn-icon">+</span><span class="btn-label"><%= __('nav_add') %></span></a>
        <details class="nav-more nav-main">
          <summary class="nav-more-btn" aria-label="Menue">Menu</summary>
          <div class="nav-more-panel">
            <details class="nav-more-sub">
              <summary class="nav-more-sub-btn">CSV</summary>
              <div class="nav-more-sub-panel">
                <a href="<%= base %>/csv"><%= __('nav_csv_import') %></a>
                <a href="<%= base %>/csv/export"><%= __('nav_csv_export') %></a>
              </div>
            </details>
            <a href="<%= base %>/items/bulk-refresh"><%= __('nav_bulk_analysis') %></a>
            <details class="nav-more-sub">
              <summary class="nav-more-sub-btn">Theme</summary>
              <div class="nav-more-sub-panel nav-theme-panel">
                <a href="javascript:void(0)" class="theme-option" data-theme="amber">Amber</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="dark">Dark</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="forest">Forest</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="gold">Gold</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="jazz">Jazz</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="matrix">Matrix</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="midnight">Midnight</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="ocean">Ocean</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="punk">Punk</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="retro">Retro</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="ruby">Ruby</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="slate">Slate</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="sunset">Sunset</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="synthwave">Synthwave</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="vinyl">Vinyl</a>
              </div>
            </details>
            <div class="nav-lang-group">
              <a href="javascript:void(0)" onclick="setLang('de')" class="lang-option<%= lang === 'de' ? ' active' : '' %>">DE</a>
              <a href="javascript:void(0)" onclick="setLang('en')" class="lang-option<%= lang === 'en' ? ' active' : '' %>">EN</a>
            </div>
          </div>
        </details>
      </nav>
    </div>
  </header>

  <main class="container">
    <a href="<%= base %>/" class="back-link">&larr; <%= __('back_to_collection') %></a>

    <div class="detail-layout">

      <!-- ── Cover ──────────────────────────────────────────────────────── -->
      <div class="detail-cover">
        <div id="cover-preview-wrap">
          <% if (item.cover_url) { %>
            <img id="cover-preview-img" src="<%= item.cover_url %>" alt="<%= item.title %>" />
          <% } else { %>
            <div id="cover-preview-img" class="cover-placeholder cover-placeholder--large"><span>🎵</span></div>
          <% } %>
        </div>
        <!-- Cover per URL laden + Vorschläge -->
        <div class="cover-url-form" id="cover-url-form">
          <input
            id="cover-url-input"
            type="url"
            placeholder="<%= __('placeholder_cover_url') %>"
            value="<%= item.cover_url || '' %>"
            autocomplete="off"
          />
          <button type="button" class="btn btn-secondary btn-sm" id="cover-url-apply"><%= __('load_btn') %></button>
        </div>
        <button
          type="button"
          class="btn btn-ghost btn-sm cover-suggest-btn"
          id="cover-suggest-btn"
          data-title="<%= (item.title  || '').replace(/"/g, '&quot;') %>"
          data-artist="<%= (item.artist || '').replace(/"/g, '&quot;') %>"
        >🎨 <%= __('cover_suggestions_btn') %></button>
        <!-- Horizontales Cover-Karussell -->
        <div class="cover-suggestions" id="cover-suggestions" style="display:none">
          <div class="cover-suggestions-track" id="cover-suggestions-track"></div>
        </div>
        <div class="detail-badges">
          <% if (item.owned)    { %><span class="badge badge-owned">✔ <%= __('label_owned') %></span><% } %>
          <% if (item.wishlist) { %><span class="badge badge-wish">♥ <%= __('label_wishlist_badge') %></span><% } %>
        </div>
        <% if (item.wishlist) { %>
          <a
            class="gh-link gh-link--detail shop-link shop-link--gh"
            href="https://greenhell.de/search/?qs=<%= encodeURIComponent((item.artist ? item.artist + ' ' : '') + item.title).replace(/%20/g, '+') %>"
            target="_blank"
            rel="noopener"
          ><%= __('shop_greenhell') %> ↗</a>
          <a
            class="gh-link gh-link--detail shop-link shop-link--amazon"
            href="https://www.amazon.de/s?k=<%= encodeURIComponent((item.artist ? item.artist + ' ' : '') + item.title) %>"
            target="_blank"
            rel="noopener"
          ><%= __('shop_amazon') %> ↗</a>
        <% } %>
      </div>

      <!-- ── Info & edit form ────────────────────────────────────────────── -->
      <div class="detail-info">
        <h1 class="page-title"><%= item.title %></h1>
        <% if (item.artist) { %><p class="detail-artist"><%= item.artist %></p><% } %>
        <% if (item.year)   { %><p class="detail-year"><%= item.year %></p><% } %>
        <% if (item.mbid)   { %>
          <p class="detail-mbid">
            <a href="https://musicbrainz.org/release/<%= item.mbid %>" target="_blank" rel="noopener">
              MusicBrainz &rsaquo;
            </a>
          </p>
        <% } %>

        <form class="form-card" method="post" action="<%= base %>/items/<%= item.id %>">

          <div class="form-group">
            <label for="title"><%= __('label_title') %></label>
            <input id="title" name="title" type="text" value="<%= item.title %>" required />
          </div>

          <div class="form-group">
            <label for="artist"><%= __('label_artist') %></label>
            <input id="artist" name="artist" type="text" value="<%= item.artist || '' %>" />
          </div>

          <input type="hidden" name="media_type" value="vinyl" />
          <div class="form-group">
            <label for="year"><%= __('label_year') %></label>
            <input id="year" name="year" type="text" maxlength="4" value="<%= item.year || '' %>" />
          </div>

          <div class="form-group form-group--inline">
            <label class="checkbox-label">
              <input type="checkbox" name="owned"    <%= item.owned    ? 'checked' : '' %> />
              <%= __('label_owned') %>
            </label>
            <label class="checkbox-label">
              <input type="checkbox" name="wishlist" <%= item.wishlist ? 'checked' : '' %> />
              <%= __('label_wishlist') %>
            </label>
          </div>

          <div class="form-group">
            <label><%= __('label_rating') %></label>
            <div class="star-input" data-field="rating">
              <% for (let i = 1; i <= 5; i++) { %>
                <span class="star <%= item.rating >= i ? 'active' : '' %>" data-value="<%= i %>">&#9733;</span>
              <% } %>
            </div>
            <input type="hidden" name="rating" id="rating" value="<%= item.rating || 0 %>" />
          </div>

          <div class="form-group">
            <label for="genre"><%= __('label_genre') %></label>
            <input id="genre" name="genre" type="text" placeholder="<%= __('placeholder_genre') %>" value="<%= item.genre || '' %>" />
          </div>
          <!-- cover_url wird über das URL-Eingabefeld im Cover-Bereich gesteuert -->
          <input type="hidden" name="cover_url" id="cover-url-hidden" value="<%= item.cover_url || '' %>" />
          <div class="form-group">
            <label for="notes"><%= __('label_notes') %></label>
            <textarea id="notes" name="notes" rows="4" placeholder="<%= __('placeholder_notes') %>"><%= item.notes || '' %></textarea>
          </div>

          <div class="form-actions">
            <button type="submit" class="btn btn-primary"><%= __('save_btn') %></button>
          </div>
        </form>
        <!-- ── Metadaten nachladen ───────────────────────────────────────── -->
        <a
          href="<%= base %>/items/<%= item.id %>/refresh"
          class="btn btn-secondary btn-refresh"
        >🔄 <%= __('refresh_metadata_btn') %></a>
        <!-- ── Delete ───────────────────────────────────────────────────── -->
        <form
          method="post"
          action="<%= base %>/items/<%= item.id %>/delete"
          class="delete-form"
          onsubmit="return confirm(__('confirm_delete_single'))"
        >
          <button type="submit" class="btn btn-danger"><%= __('delete_btn') %></button>
        </form>

        <p class="detail-created">
          <%= __('added_on') %>: <%= new Date(item.created_at).toLocaleDateString(lang === 'de' ? 'de-DE' : 'en-US') %>
        </p>
      </div>
    </div>
  </main>

  <footer class="site-footer">
    <small><%= __('footer') %></small>
  </footer>
  <script>
    const BASE = '<%= base %>';
    function escHtml(s) {
      return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    // ── Cover-Karussell (MusicBrainz-Vorschläge) ───────────────────────────
    const suggestBtn    = document.getElementById('cover-suggest-btn');
    const suggestionsEl = document.getElementById('cover-suggestions');
    const suggestTrack  = document.getElementById('cover-suggestions-track');
    let suggestLoaded   = false;

    suggestBtn.addEventListener('click', async () => {
      if (suggestLoaded) {
        const visible = suggestionsEl.style.display !== 'none';
        suggestionsEl.style.display = visible ? 'none' : '';
        suggestBtn.textContent = visible ? '🎨 ' + __('cover_suggestions_btn') : '🎨 ' + __('hide_suggestions_btn');
        return;
      }
      suggestBtn.disabled     = true;
      suggestBtn.textContent  = '⏳ ' + __('loading');
      try {
        const params = new URLSearchParams({ q: suggestBtn.dataset.title });
        if (suggestBtn.dataset.artist) params.set('artist', suggestBtn.dataset.artist);
        const res  = await fetch(`${BASE}/api/search?${params}`);
        const sugs = await res.json();
        const withCover = sugs.filter(s => s.cover_url || s.rg_cover_url);
        if (!withCover.length) {
          suggestTrack.innerHTML = '<span class="cover-sug-none">' + __('no_cover_suggestions') + '</span>';
        } else {
          suggestTrack.innerHTML = withCover.map(s => {
            const primary  = s.cover_url || s.rg_cover_url;
            const fallback = s.cover_url && s.rg_cover_url ? s.rg_cover_url : '';
            return `<button
            type="button"
            class="cover-sug-item"
            title="${escHtml(s.artist)} – ${escHtml(s.title)}\n${escHtml(s.year)}"
            data-url="${escHtml(primary)}"
            data-rg-url="${escHtml(fallback)}"
            onclick="pickCover(this)"
          ><img src="${escHtml(primary)}" alt="" loading="lazy"
            onerror="if(this.dataset.fallback!=='1'&&this.closest('button').dataset.rgUrl){this.dataset.fallback='1';this.src=this.closest('button').dataset.rgUrl;}else{this.closest('.cover-sug-item').style.display='none';}"
          /><span class="cover-sug-label">${escHtml(s.year)}</span></button>`;
          }).join('');
        }
        suggestLoaded = true;
        suggestionsEl.style.display = '';
        suggestBtn.textContent = '🎨 ' + __('hide_suggestions_btn');
      } catch {
        suggestBtn.textContent = '⚠ ' + __('error');
      }
      suggestBtn.disabled = false;
    });

    function pickCover(btn) {
      // Nimm die tatsächlich geladene Bild-URL (ggf. Fallback auf Release-Group)
      const img = btn.querySelector('img');
      const url = (img && img.src) ? img.src : btn.dataset.url;
      document.getElementById('cover-url-input').value  = url;
      document.getElementById('cover-url-hidden').value = url;
      loadPreview(url);
      document.querySelectorAll('.cover-sug-item').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
    }

    // ── Cover-URL Vorschau & Übernahme ──────────────────────────────────
    const urlInput   = document.getElementById('cover-url-input');
    const urlHidden  = document.getElementById('cover-url-hidden');
    const applyBtn   = document.getElementById('cover-url-apply');
    const previewWrap = document.getElementById('cover-preview-wrap');

    function loadPreview(url) {
      url = url.trim();
      if (!url) return;
      const img = new Image();
      img.onload = () => {
        previewWrap.innerHTML = `<img id="cover-preview-img" src="${escHtml(url)}" alt="Cover" />`;
        urlHidden.value = url;
        applyBtn.textContent = '✔ ' + __('cover_loaded');
        applyBtn.style.color = 'var(--color-success, #4caf50)';
        setTimeout(() => { applyBtn.textContent = __('load_btn'); applyBtn.style.color = ''; }, 2000);
      };
      img.onerror = () => {
        applyBtn.textContent = '✘ ' + __('cover_not_loadable');
        applyBtn.style.color = 'var(--color-danger)';
        setTimeout(() => { applyBtn.textContent = __('load_btn'); applyBtn.style.color = ''; }, 2500);
      };
      img.src = url;
    }

    applyBtn.addEventListener('click', () => loadPreview(urlInput.value));
    urlInput.addEventListener('keydown', e => { if (e.key === 'Enter') { e.preventDefault(); loadPreview(urlInput.value); } });
    // Hidden-Feld sofort beim Tippen synchronisieren, damit auch ohne "Laden" gespeichert wird
    urlInput.addEventListener('input', () => { urlHidden.value = urlInput.value.trim(); });
    // Beim Einfügen (Paste) sofort Vorschau laden
    urlInput.addEventListener('paste', e => {
      const pasted = (e.clipboardData || window.clipboardData).getData('text');
      setTimeout(() => { urlHidden.value = pasted.trim(); loadPreview(pasted); }, 50);
    });

    // ── Sterne-Rating Widget ──────────────────────────────────────────
    document.querySelectorAll('.star-input').forEach(widget => {
      const field = document.getElementById(widget.dataset.field);
      const stars = widget.querySelectorAll('.star');
      stars.forEach((star, idx) => {
        star.addEventListener('click', () => {
          const val = idx + 1;
          field.value = (Number(field.value) === val) ? 0 : val;
          updateStars(widget, Number(field.value));
        });
        star.addEventListener('mouseenter', () => updateStars(widget, idx + 1));
      });
      widget.addEventListener('mouseleave', () => updateStars(widget, Number(field.value)));
    });
    function updateStars(widget, val) {
      widget.querySelectorAll('.star').forEach((s, i) => s.classList.toggle('active', i < val));
    }
  </script>
  <script src="<%= base %>/public/theme-selector.js?v=<%= assetVersion %>"></script>
</body>
</html>
