<%
  /*
   * views/add.ejs
   * Zwei-Tab-Formular zum Hinzufügen eines neuen Mediums:
   *   Tab 1: Release direkt suchen (Titel + Künstler → Treffer)
   *   Tab 2: Künstler suchen → Diskografie → Auswählen
   * Wenn ein Ergebnis ausgewählt wird, füllt JS das finale Formular aus.
   */
%>
<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= __('add_page_title') %> – VinylVault</title>
  <link rel="stylesheet" href="<%= base %>/public/style.css?v=<%= assetVersion %>" />
  <link rel="stylesheet" href="<%= base %>/public/themes.css?v=<%= assetVersion %>" />
  <%- include('partials/head-i18n') %>
</head>
<body>
  <header class="site-header">
    <a class="logo" href="<%= base %>/">
      <span class="logo-icon">🎵</span>
      <span class="logo-text">VinylVault</span>
    </a>
    <div class="nav-wrap">
      <nav class="nav-primary">
        <a class="btn btn-ghost nav-link-collection" href="<%= base %>/"><span class="btn-icon"><svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="2" /><circle cx="12" cy="12" r="2" fill="currentColor" /></svg></span><span class="btn-label"><%= __('nav_collection') %></span></a>
        <a href="<%= base %>/items/wishlist-add" class="btn btn-secondary"><span class="btn-icon">♥</span><span class="btn-label"><%= __('nav_wishlist') %></span></a>
        <a href="<%= base %>/items/add" class="btn btn-primary"><span class="btn-icon">+</span><span class="btn-label"><%= __('nav_add') %></span></a>
        <details class="nav-more nav-main">
          <summary class="nav-more-btn" aria-label="Menue">Menu</summary>
          <div class="nav-more-panel">
            <details class="nav-more-sub">
              <summary class="nav-more-sub-btn">CSV</summary>
              <div class="nav-more-sub-panel">
                <a href="<%= base %>/csv"><%= __('nav_csv_import') %></a>
                <a href="<%= base %>/csv/export"><%= __('nav_csv_export') %></a>
              </div>
            </details>
            <a href="<%= base %>/items/bulk-refresh"><%= __('nav_bulk_analysis') %></a>
            <details class="nav-more-sub">
              <summary class="nav-more-sub-btn">Theme</summary>
              <div class="nav-more-sub-panel nav-theme-panel">
                <a href="javascript:void(0)" class="theme-option" data-theme="amber">Amber</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="dark">Dark</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="forest">Forest</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="gold">Gold</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="jazz">Jazz</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="matrix">Matrix</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="midnight">Midnight</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="ocean">Ocean</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="punk">Punk</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="retro">Retro</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="ruby">Ruby</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="slate">Slate</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="sunset">Sunset</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="synthwave">Synthwave</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="vinyl">Vinyl</a>
              </div>
            </details>
            <div class="nav-lang-group">
              <a href="javascript:void(0)" onclick="setLang('de')" class="lang-option<%= lang === 'de' ? ' active' : '' %>">DE</a>
              <a href="javascript:void(0)" onclick="setLang('en')" class="lang-option<%= lang === 'en' ? ' active' : '' %>">EN</a>
            </div>
          </div>
        </details>
      </nav>
    </div>
  </header>

  <main class="container">
    <h1 class="page-title"><%= __('add_new_item') %></h1>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <!-- ── Tabs ──────────────────────────────────────────────────────────── -->
    <div class="tabs">
      <button class="tab-btn active" data-tab="release">🔍 <%= __('tab_search_release') %></button>
      <button class="tab-btn"        data-tab="artist"> 🎤 <%= __('tab_search_artist') %></button>
      <button class="tab-btn"        data-tab="manual"> ✏️ <%= __('tab_manual') %></button>
    </div>

    <!-- ── Tab: Release-Suche ─────────────────────────────────────────────── -->
    <div id="tab-release" class="tab-panel active">
      <div class="search-bar">
        <input id="rel-title"  type="text" placeholder="<%= __('placeholder_title') %>" />
        <input id="rel-artist" type="text" placeholder="<%= __('placeholder_artist') %>" />
        <button id="rel-search-btn" class="btn btn-primary"><%= __('search_btn') %></button>
      </div>
      <div id="rel-results" class="search-results"></div>
    </div>

    <!-- ── Tab: Künstler-Suche ─────────────────────────────────────────────── -->
    <div id="tab-artist" class="tab-panel">
      <div class="search-bar">
        <input id="art-query" type="text" placeholder="<%= __('placeholder_artist_name') %>" />
        <button id="art-search-btn" class="btn btn-primary"><%= __('search_btn') %></button>
      </div>
      <div id="art-results"  class="search-results"></div>
      <div id="disc-results" class="search-results" style="display:none"></div>
    </div>

    <!-- ── Tab: Manuell ───────────────────────────────────────────────────── -->
    <div id="tab-manual" class="tab-panel">
      <form class="form-card" method="post" action="<%= base %>/items/add">
        <div class="form-group">
          <label for="m-title"><%= __('label_title') %> <span class="required">*</span></label>
          <input id="m-title" name="title" type="text" required placeholder="<%= __('placeholder_enter_title') %>" autofocus />
        </div>
        <div class="form-group">
          <label for="m-artist"><%= __('label_artist') %></label>
          <input id="m-artist" name="artist" type="text" placeholder="<%= __('placeholder_artist_interpret') %>" />
        </div>
        <div class="form-group">
          <label for="m-genre"><%= __('label_genre') %></label>
          <input id="m-genre" name="genre" type="text" placeholder="<%= __('placeholder_genre') %>" />
        </div>
        <input type="hidden" name="media_type" value="vinyl" />
        <div class="form-group form-group--inline">
          <label class="checkbox-label"><input type="checkbox" name="owned"    /> <%= __('label_owned') %></label>
          <label class="checkbox-label"><input type="checkbox" name="wishlist" /> <%= __('label_wishlist') %></label>
        </div>
        <div class="form-actions">
          <a href="<%= base %>/" class="btn btn-ghost"><%= __('cancel_btn') %></a>
          <button type="submit" class="btn btn-primary"><%= __('save_btn') %></button>
        </div>
      </form>
    </div>

    <!-- ── Bestätigungsformular (wird per JS ausgefüllt) ─────────────────── -->
    <div id="confirm-panel" class="confirm-panel" style="display:none">
      <h2 class="confirm-title"><%= __('selected') %></h2>
      <div class="confirm-preview">
        <img id="confirm-cover" src="" alt="" />
        <div>
          <p id="confirm-label-title"  class="confirm-item-title"></p>
          <p id="confirm-label-artist" class="confirm-item-artist"></p>
          <p id="confirm-label-year"   class="confirm-item-year"></p>
        </div>
      </div>
      <form class="form-card" method="post" action="<%= base %>/items/add">
        <input type="hidden" name="title"     id="cf-title"     />
        <input type="hidden" name="artist"    id="cf-artist"    />
        <input type="hidden" name="year"      id="cf-year"      />
        <input type="hidden" name="cover_url" id="cf-cover_url" />
        <input type="hidden" name="mbid"      id="cf-mbid"      />

        <input type="hidden" name="media_type" value="vinyl" />
        <div class="form-group form-group--inline">
          <label class="checkbox-label"><input type="checkbox" name="owned"    /> <%= __('label_owned') %></label>
          <label class="checkbox-label"><input type="checkbox" name="wishlist" /> <%= __('label_wishlist') %></label>
        </div>
        <div class="form-group">
          <label><%= __('label_rating') %></label>
          <div class="star-input" id="cf-star-input" data-field="cf-rating">
            <% for (let i = 1; i <= 5; i++) { %>
              <span class="star" data-value="<%= i %>">★</span>
            <% } %>
          </div>
          <input type="hidden" name="rating" id="cf-rating" value="0" />
        </div>
        <div class="form-group">
          <label for="cf-genre"><%= __('label_genre') %></label>
          <input id="cf-genre" name="genre" type="text" placeholder="<%= __('placeholder_genre') %>" />
        </div>
        <div class="form-actions">
          <button type="button" class="btn btn-ghost" onclick="closeConfirm()"><%= __('cancel_btn') %></button>
          <button type="submit" class="btn btn-primary"><%= __('save_btn') %></button>
        </div>
      </form>
    </div>
  </main>

  <footer class="site-footer">
    <small><%= __('footer') %></small>
  </footer>

  <script>
    const BASE = '<%= base %>';

    // ── Tabs ────────────────────────────────────────────────────────────────
    document.querySelectorAll('.tab-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
        btn.classList.add('active');
        document.getElementById('tab-' + btn.dataset.tab).classList.add('active');
      });
    });

    // ── Hilfsfunktionen ─────────────────────────────────────────────────────
    function coverImg(url, title) {
      if (!url) return `<div class="cover-placeholder"><span>?</span></div>`;
      return `<img src="${url}" alt="${escHtml(title)}" loading="lazy"
                   onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
              /><div class="cover-placeholder" style="display:none"><span>?</span></div>`;
    }
    function escHtml(s) {
      return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }
    function setLoading(el) { el.innerHTML = '<p class="search-loading">' + __('searching') + '</p>'; }
    function setError(el, msg) { el.innerHTML = `<p class="search-error">${msg}</p>`; }

    // ── Ausgewähltes Release ins Bestätigungsformular übertragen ───────────
    function selectRelease(r) {
      document.getElementById('cf-title').value     = r.title     || '';
      document.getElementById('cf-artist').value    = r.artist    || '';
      document.getElementById('cf-year').value      = r.year      || '';
      document.getElementById('cf-cover_url').value = r.cover_url || '';
      document.getElementById('cf-mbid').value      = r.mbid      || '';

      document.getElementById('confirm-label-title').textContent  = r.title  || '';
      document.getElementById('confirm-label-artist').textContent = r.artist || '';
      document.getElementById('confirm-label-year').textContent   = r.year   || '';

      const img = document.getElementById('confirm-cover');
      if (r.cover_url) { img.src = r.cover_url; img.style.display = ''; }
      else              { img.style.display = 'none'; }

      document.getElementById('confirm-panel').style.display = '';
      document.getElementById('confirm-panel').scrollIntoView({ behavior: 'smooth' });
    }
    function closeConfirm() {
      document.getElementById('confirm-panel').style.display = 'none';
    }

    // ── Release-Karte als HTML ───────────────────────────────────────────────
    function releaseCard(r) {
      return `
        <div class="result-card"
             data-title="${escHtml(r.title || '')}"
             data-artist="${escHtml(r.artist || '')}"
             data-year="${escHtml(r.year || '')}"
             data-cover="${escHtml(r.cover_url || '')}"
             data-mbid="${escHtml(r.mbid || '')}"
             onclick="selectReleaseFromCard(this)">
          <div class="result-cover">${coverImg(r.cover_url, r.title)}</div>
          <div class="result-info">
            <p class="result-title">${escHtml(r.title)}</p>
            <p class="result-artist">${escHtml(r.artist)}</p>
            <p class="result-year">${escHtml(r.year)}${r.type ? ' · '+escHtml(r.type) : ''}</p>
          </div>
          <span class="result-add-icon">＋</span>
        </div>`;
    }
    function selectReleaseFromCard(el) {
      selectRelease({
        title:     el.dataset.title  || '',
        artist:    el.dataset.artist || '',
        year:      el.dataset.year   || '',
        cover_url: el.dataset.cover  || '',
        mbid:      el.dataset.mbid   || '',
      });
    }

    // ── Tab 1: Release suchen ────────────────────────────────────────────────
    async function searchReleases() {
      const title  = document.getElementById('rel-title').value.trim();
      const artist = document.getElementById('rel-artist').value.trim();
      if (!title) return;
      const el = document.getElementById('rel-results');
      setLoading(el);
      try {
        const params = new URLSearchParams({ q: title });
        if (artist) params.set('artist', artist);
        const res  = await fetch(`${BASE}/api/search?${params}`);
        const data = await res.json();
        if (!data.length) { el.innerHTML = '<p class="search-empty">' + __('no_results_found') + '</p>'; return; }
        el.innerHTML = data.map(releaseCard).join('');
      } catch { setError(el, __('search_failed')); }
    }
    document.getElementById('rel-search-btn').addEventListener('click', searchReleases);
    document.getElementById('rel-title').addEventListener('keydown',  e => e.key==='Enter' && searchReleases());
    document.getElementById('rel-artist').addEventListener('keydown', e => e.key==='Enter' && searchReleases());

    // ── Tab 2: Künstler suchen ───────────────────────────────────────────────
    async function searchArtists() {
      const q = document.getElementById('art-query').value.trim();
      if (!q) return;
      const el = document.getElementById('art-results');
      document.getElementById('disc-results').style.display = 'none';
      setLoading(el);
      try {
        const res  = await fetch(`${BASE}/api/artists?q=${encodeURIComponent(q)}`);
        const data = await res.json();
        if (!data.length) { el.innerHTML = '<p class="search-empty">' + __('no_artists_found') + '</p>'; return; }
        el.innerHTML = data.map(a => `
          <div class="artist-card" onclick="loadDiscography('${escHtml(a.mbid)}','${escHtml(a.name).replace(/'/g, '&#39;')}')">
            <span class="artist-name">${escHtml(a.name)}</span>
            ${a.disambiguation ? `<span class="artist-dis">${escHtml(a.disambiguation)}</span>` : ''}
            ${a.country         ? `<span class="artist-country">${escHtml(a.country)}</span>` : ''}
          </div>`).join('');
      } catch { setError(el, __('search_failed')); }
    }
    document.getElementById('art-search-btn').addEventListener('click', searchArtists);
    document.getElementById('art-query').addEventListener('keydown', e => e.key==='Enter' && searchArtists());

    // ── Diskografie laden ────────────────────────────────────────────────────
    async function loadDiscography(mbid, name) {
      const el = document.getElementById('disc-results');
      el.style.display = '';
      el.innerHTML = `<p class="search-loading">${__('loading_discography').replace('{name}', escHtml(name))}</p>`;
      el.scrollIntoView({ behavior: 'smooth' });
      try {
        const res  = await fetch(`${BASE}/api/artists/${mbid}/releases`);
        const data = await res.json();
        if (!data.length) { el.innerHTML = '<p class="search-empty">' + __('no_releases_found') + '</p>'; return; }
        el.innerHTML = `<h3 class="disc-heading">${__('discography_of').replace('{name}', escHtml(name))}</h3>` + data.map(releaseCard).join('');
      } catch { setError(el, __('discography_failed')); }
    }

    // ── Sterne-Rating ────────────────────────────────────────────────────────
    document.querySelectorAll('.star-input').forEach(widget => {
      const field = document.getElementById(widget.dataset.field);
      const stars = widget.querySelectorAll('.star');
      stars.forEach((star, idx) => {
        star.addEventListener('click', () => {
          const val = idx + 1;
          field.value = (Number(field.value) === val) ? 0 : val; // zweiter Klick = zurücksetzen
          updateStars(widget, Number(field.value));
        });
        star.addEventListener('mouseenter', () => updateStars(widget, idx + 1));
      });
      widget.addEventListener('mouseleave', () => updateStars(widget, Number(field.value)));
    });
    function updateStars(widget, val) {
      widget.querySelectorAll('.star').forEach((s, i) => s.classList.toggle('active', i < val));
    }
  </script>
  <script src="<%= base %>/public/theme-selector.js?v=<%= assetVersion %>"></script>
</body>
</html>
