<%
  /*
   * views/bulk-refresh.ejs
   * Massenanalyse: alle Einträge in einer Tabelle, MusicBrainz-Vorschläge
   * werden parallel geladen (server-seitig rate-limitiert → progressiv).
   */
%>
<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= __('bulk_page_title') %> – VinylVault</title>
  <link rel="stylesheet" href="<%= base %>/public/style.css?v=<%= assetVersion %>" />
  <link rel="stylesheet" href="<%= base %>/public/themes.css?v=<%= assetVersion %>" />
  <%- include('partials/head-i18n') %>
</head>
<body>
  <header class="site-header">
    <a class="logo" href="<%= base %>/">
      <span class="logo-icon">🎵</span>
      <span class="logo-text">VinylVault</span>
    </a>
    <div class="nav-wrap">
      <nav class="nav-primary">
        <a class="btn btn-ghost nav-link-collection" href="<%= base %>/"><span class="btn-icon"><svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="2" /><circle cx="12" cy="12" r="2" fill="currentColor" /></svg></span><span class="btn-label"><%= __('nav_collection') %></span></a>
        <a href="<%= base %>/items/wishlist-add" class="btn btn-secondary"><span class="btn-icon">♥</span><span class="btn-label"><%= __('nav_wishlist') %></span></a>
        <a href="<%= base %>/items/add" class="btn btn-primary"><span class="btn-icon">+</span><span class="btn-label"><%= __('nav_add') %></span></a>
        <details class="nav-more nav-main">
          <summary class="nav-more-btn" aria-label="Menue">Menu</summary>
          <div class="nav-more-panel">
            <details class="nav-more-sub">
              <summary class="nav-more-sub-btn">CSV</summary>
              <div class="nav-more-sub-panel">
                <a href="<%= base %>/csv"><%= __('nav_csv_import') %></a>
                <a href="<%= base %>/csv/export"><%= __('nav_csv_export') %></a>
              </div>
            </details>
            <a href="<%= base %>/items/bulk-refresh"><%= __('nav_bulk_analysis') %></a>
            <details class="nav-more-sub">
              <summary class="nav-more-sub-btn">Theme</summary>
              <div class="nav-more-sub-panel nav-theme-panel">
                <a href="javascript:void(0)" class="theme-option" data-theme="amber">Amber</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="dark">Dark</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="forest">Forest</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="gold">Gold</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="jazz">Jazz</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="matrix">Matrix</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="midnight">Midnight</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="ocean">Ocean</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="punk">Punk</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="retro">Retro</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="ruby">Ruby</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="slate">Slate</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="sunset">Sunset</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="synthwave">Synthwave</a>
                <a href="javascript:void(0)" class="theme-option" data-theme="vinyl">Vinyl</a>
              </div>
            </details>
            <div class="nav-lang-group">
              <a href="javascript:void(0)" onclick="setLang('de')" class="lang-option<%= lang === 'de' ? ' active' : '' %>">DE</a>
              <a href="javascript:void(0)" onclick="setLang('en')" class="lang-option<%= lang === 'en' ? ' active' : '' %>">EN</a>
            </div>
          </div>
        </details>
      </nav>
    </div>
  </header>

  <main class="container container--wide">
    <div class="bulk-header">
      <div>
        <h1 class="page-title" style="margin-bottom:.25rem"><%= __('bulk_page_title') %></h1>
        <p class="page-subtitle">
          <strong><%= __('n_entries_no_cover').replace('{n}', items.length) %></strong>
          <span style="color:var(--color-muted)">(<%= __('n_total').replace('{n}', totalAll) %>)</span>
          &mdash; <%= __('bulk_desc') %>
        </p>
      </div>
      <div class="bulk-header-actions">
        <span class="bulk-progress" id="progress-label"></span>
        <button id="btn-start" class="btn btn-primary"><%= __('start_search_btn') %></button>
        <button id="btn-stop"  class="btn btn-ghost"  style="display:none"><%= __('stop_btn') %></button>
      </div>
    </div>

    <div class="bulk-table-wrap">
      <table class="bulk-table" id="bulk-table">
        <thead>
          <tr>
            <th class="bt-col-cover"></th>
            <th class="bt-col-info"><%= __('col_current_entry') %></th>
            <% for (let s = 1; s <= 5; s++) { %>
            <th class="bt-col-sug"><%= __('suggestion_n').replace('{n}', s) %></th>
            <% } %>
          </tr>
        </thead>
        <tbody>
          <% if (items.length === 0) { %>
            <tr><td colspan="7" style="text-align:center;padding:2.5rem;color:var(--color-muted);"><%= __('all_have_covers') %></td></tr>
          <% } %>
          <% for (const item of items) { %>
            <tr
              class="bt-row"
              id="row-<%= item.id %>"
              data-id="<%= item.id %>"
              data-title="<%= (item.title  || '').replace(/"/g, '&quot;') %>"
              data-artist="<%= (item.artist || '').replace(/"/g, '&quot;') %>"
            >
              <!-- Cover -->
              <td class="bt-col-cover">
                <% if (item.cover_url) { %>
                  <img
                    class="bt-cover"
                    src="<%= item.cover_url %>"
                    alt=""
                    loading="lazy"
                    onerror="this.style.display='none'"
                  />
                <% } else { %>
                  <div class="bt-cover bt-cover--placeholder">🎵</div>
                <% } %>
              </td>
              <!-- Aktueller Eintrag -->
              <td class="bt-col-info">
                <a class="bt-item-link" href="<%= base %>/items/<%= item.id %>">
                  <span class="bt-item-title"><%= item.title %></span>
                  <% if (item.artist) { %>
                    <span class="bt-item-artist"><%= item.artist %></span>
                  <% } %>
                </a>
                <span class="bt-item-meta">
                  <% if (item.year) { %><span class="bt-year"><%= item.year %></span><% } %>
                  <% if (item.mbid) { %><span class="bt-mbid-dot" title="<%= __('mbid_present') %>">●</span><% } %>
                </span>
                <span class="bt-row-status" id="status-<%= item.id %>"></span>
              </td>
              <!-- 5 Vorschlags-Slots -->
              <% for (let s = 1; s <= 5; s++) { %>
                <td class="bt-col-sug" id="sug-<%= item.id %>-<%= s %>">
                  <div class="bt-sug-empty">–</div>
                </td>
              <% } %>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </main>

  <footer class="site-footer">
    <small><%= __('footer') %></small>
  </footer>

  <script>
    const BASE    = '<%= base %>';
    let stopped   = false;
    let total     = 0;
    let done      = 0;

    const btnStart  = document.getElementById('btn-start');
    const btnStop   = document.getElementById('btn-stop');
    const progLabel = document.getElementById('progress-label');

    function escHtml(s) {
      return String(s || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    function setProgress(d, t) {
      progLabel.textContent = __('progress_loaded').replace('{done}', d).replace('{total}', t);
    }

    // Suggestion-Karte als HTML
    function sugCard(itemId, sug) {
      const coverHtml = sug.cover_url
        ? `<img class="bt-sug-cover" src="${escHtml(sug.cover_url)}" alt="" loading="lazy"
              onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"/>
           <div class="bt-sug-cover bt-cover--placeholder" style="display:none">?</div>`
        : `<div class="bt-sug-cover bt-cover--placeholder">?</div>`;

      const score = sug.score != null
        ? `<span class="refresh-score refresh-score--${sug.score >= 90 ? 'high' : sug.score >= 60 ? 'mid' : 'low'}">${sug.score}%</span>`
        : '';

        // Daten als data-* Attribute – sicher gegen Anführungszeichen in Metadaten
      return `
        <div class="bt-sug-card" title="${escHtml(sug.artist)} – ${escHtml(sug.title)} (${escHtml(sug.year)})">
          ${coverHtml}
          <div class="bt-sug-info">
            <span class="bt-sug-title">${escHtml(sug.title)}</span>
            <span class="bt-sug-artist">${escHtml(sug.artist)}</span>
            <span class="bt-sug-year">${escHtml(sug.year)} ${score}</span>
          </div>
          <button
            class="bt-sug-apply"
            title="${__('apply_btn_title')}"
            data-item-id="${itemId}"
            data-title="${escHtml(sug.title)}"
            data-artist="${escHtml(sug.artist)}"
            data-year="${escHtml(sug.year)}"
            data-cover="${escHtml(sug.cover_url || '')}"
            data-mbid="${escHtml(sug.mbid || '')}"
            data-genre="${escHtml(sug.genre || '')}"
            onclick="handleApply(this)"
          >✔</button>
        </div>`;
    }

    // Metadaten anwenden ohne Seitenwechsel – liest data-* vom Button
    function handleApply(btn) {
      const { itemId, title, artist, year, cover, mbid, genre } = btn.dataset;
      applyAndMark(Number(itemId), btn, title, artist, year, cover, mbid, genre);
    }

    // Metadaten anwenden ohne Seitenwechsel
    async function applyAndMark(itemId, btn, title, artist, year, cover_url, mbid, genre) {
      btn.disabled    = true;
      btn.textContent = '…';
      try {
        const resp = await fetch(`${BASE}/items/${itemId}/refresh/apply?json=1`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ title, artist, year, cover_url, mbid, genre }),
        });
        const data = resp.ok ? await resp.json().catch(() => ({})) : {};
        if (resp.ok && data.ok) {
          // Zeile als "erledigt" markieren
          const row = document.getElementById('row-' + itemId);
          row?.classList.add('bt-row--applied');
          document.getElementById('status-' + itemId).innerHTML =
            '<span class="bt-applied-badge">✔ ' + __('applied_badge') + '</span>';
          // Cover in der ersten Spalte aktualisieren
          const coverCell = row?.querySelector('.bt-cover, .bt-cover--placeholder');
          if (coverCell && cover_url) {
            coverCell.outerHTML = `<img class="bt-cover" src="${escHtml(cover_url)}" alt="" loading="lazy" onerror="this.style.display='none'" />`;
          }
        } else {
          btn.textContent = '✘';
          btn.style.color = 'var(--color-danger)';
          btn.disabled    = false;
        }
      } catch (err) {
        btn.textContent = '✘ ' + (err.message || __('error'));
        btn.disabled    = false;
      }
    }

    // Einen Eintrag suchen und Spalten befüllen
    async function fetchRow(row) {
      if (stopped) return;
      const id     = row.dataset.id;
      const title  = row.dataset.title;
      const artist = row.dataset.artist;
      const status = document.getElementById('status-' + id);

      status.innerHTML = '<span class="bt-loading">…</span>';

      try {
        const params = new URLSearchParams({ q: title });
        if (artist) params.set('artist', artist);
        const res  = await fetch(`${BASE}/api/search?${params}`);
        const sugs = await res.json();

        // Slots befüllen
        for (let i = 0; i < 5; i++) {
          const cell = document.getElementById(`sug-${id}-${i + 1}`);
          if (!cell) continue;
          if (sugs[i]) {
            cell.innerHTML = sugCard(Number(id), sugs[i]);
          } else {
            cell.innerHTML = '<div class="bt-sug-empty">–</div>';
          }
        }
        status.innerHTML = sugs.length
          ? `<span class="bt-found">${__('n_results_found').replace('{n}', sugs.length)}</span>`
          : '<span class="bt-not-found">' + __('no_match') + '</span>';
      } catch {
        status.innerHTML = '<span class="bt-error">' + __('error') + '</span>';
      }

      done++;
      setProgress(done, total);
      if (done >= total) {
        btnStop.style.display  = 'none';
        btnStart.style.display = '';
        btnStart.textContent   = __('search_again_btn');
        btnStart.disabled      = false;
      }
    }

    btnStart.addEventListener('click', () => {
      stopped = false;
      done    = 0;
      const rows = [...document.querySelectorAll('.bt-row')];
      total = rows.length;
      setProgress(0, total);
      btnStart.style.display = 'none';
      btnStop.style.display  = '';

      // Alle Requests gleichzeitig abschicken –
      // server-seitiger Rate-Limiter queued sie auf 1/1.15s
      rows.forEach(row => fetchRow(row));
    });

    btnStop.addEventListener('click', () => {
      stopped = true;
      btnStop.style.display  = 'none';
      btnStart.style.display = '';
      btnStart.disabled      = false;
      btnStart.textContent   = __('continue_search_btn');
    });
  </script>
  <script src="<%= base %>/public/theme-selector.js?v=<%= assetVersion %>"></script>
</body>
</html>
